{
  "name": "pdyform-builder",
  "version": "1.0.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LaoChen1994/pdyform",
    "directory": "packages/builder"
  },
  "bugs": {
    "url": "https://github.com/LaoChen1994/pdyform/issues"
  },
  "homepage": "https://github.com/LaoChen1994/pdyform/tree/main/packages/builder#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.tsx --tsconfig tsconfig.build.json --format cjs,esm --dts --clean --external react --external react-dom --external pdyform-core --external pdyform-react",
    "dev": "tsup src/index.tsx --tsconfig tsconfig.build.json --format cjs,esm --watch --dts --external react --external react-dom --external pdyform-core --external pdyform-react",
    "lint": "oxlint --ignore-pattern dist"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "immer": "^11.1.8",
    "lucide-react": "^0.300.0",
    "pdyform-core": "workspace:*",
    "pdyform-react": "workspace:*",
    "tailwind-merge": "^2.6.1",
    "zustand": "^4.5.2"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
